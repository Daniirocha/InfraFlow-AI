DATABASE_URL="postgresql://infraflow:infraflow@localhost:5432/infraflow?schema=public"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

JWT_ACCESS_SECRET="troque-por-uma-string-longa-e-aleatoria"
JWT_ACCESS_EXPIRES="15m"

# Opcional: Google AI Studio / Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Filas BullMQ + Redis (opcional; sem isso a API funciona sem filas)
REDIS_ENABLED="false"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
